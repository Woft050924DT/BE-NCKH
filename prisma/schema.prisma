  faculties                  faculties?               @relation(fields: [faculty_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  thesis_types               thesis_types             @relation(fields: [thesis_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([department_id], map: "idx_thesis_rounds_department")
  @@index([faculty_id], map: "idx_thesis_rounds_faculty")
  @@index([thesis_type_id], map: "idx_thesis_rounds_type")
}

model thesis_tasks {
  id                                          Int       @id @default(autoincrement())
  thesis_id                                   Int
  task_name                                   String    @db.VarChar(255)
  task_description                            String?
  assigned_to                                 Int?
  start_date                                  DateTime? @db.Date
  due_date                                    DateTime? @db.Date
  completed_date                              DateTime? @db.Date
  status                                      String?   @default("PENDING") @db.VarChar(50)
  priority                                    String?   @default("MEDIUM") @db.VarChar(20)
  progress_percentage                         Int?      @default(0)
  attachment_file                             String?   @db.VarChar(255)
  created_by                                  Int?
  created_at                                  DateTime? @default(now()) @db.Timestamp(6)
  updated_at                                  DateTime? @default(now()) @db.Timestamp(6)
  students_thesis_tasks_assigned_toTostudents students? @relation("thesis_tasks_assigned_toTostudents", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students_thesis_tasks_created_byTostudents  students? @relation("thesis_tasks_created_byTostudents", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  theses                                      theses    @relation(fields: [thesis_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([assigned_to, status], map: "idx_thesis_tasks_assigned")
}

model thesis_types {
  id             Int             @id @default(autoincrement())
  type_code      String          @unique @db.VarChar(20)
  type_name      String          @db.VarChar(100)
  description    String?
  has_review     Boolean?        @default(true)
  has_defense    Boolean?        @default(true)
  reviewer_count Int?            @default(1)
  status         Boolean?        @default(true)
  thesis_rounds  thesis_rounds[]
}

model topic_registrations {
  id                          Int              @id @default(autoincrement())
  thesis_group_id             Int
  thesis_round_id             Int
  instructor_id               Int
  proposed_topic_id           Int?
  self_proposed_title         String?          @db.VarChar(500)
  self_proposed_description   String?
  selection_reason            String?
  applied_group_mode          String?          @db.VarChar(20)
  applied_min_members         Int?
  applied_max_members         Int?
  rule_override_by            String?          @db.VarChar(20)
  rule_override_reason        String?
  instructor_status           String?          @default("PENDING") @db.VarChar(100)
  head_status                 String?          @default("PENDING") @db.VarChar(100)
  instructor_rejection_reason String?
  head_rejection_reason       String?
  head_override_group_mode    String?          @db.VarChar(20)
  head_override_min_members   Int?
  head_override_max_members   Int?
  head_override_reason        String?
  registration_date           DateTime?        @default(now()) @db.Timestamp(6)
  instructor_approval_date    DateTime?        @db.Timestamp(6)
  head_approval_date          DateTime?        @db.Timestamp(6)
  updated_at                  DateTime         @default(now()) @db.Timestamp(6)
  theses                      theses?
  instructors                 instructors      @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proposed_topics             proposed_topics? @relation(fields: [proposed_topic_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  thesis_groups               thesis_groups    @relation(fields: [thesis_group_id, thesis_round_id], references: [id, thesis_round_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([thesis_group_id, thesis_round_id])
  @@unique([id, thesis_group_id], map: "uq_topic_registrations_id_group")
  @@index([thesis_group_id], map: "idx_topic_registrations_group")
  @@index([thesis_round_id], map: "idx_topic_registrations_round")
  @@index([instructor_status, head_status], map: "idx_topic_registrations_status")
}

model typing_status {
  id              Int           @id @default(autoincrement())
  conversation_id Int
  user_id         Int
  is_typing       Boolean?      @default(true)
  started_at      DateTime?     @default(now()) @db.Timestamp(6)
  conversations   conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([conversation_id, user_id])
}

model user_role_assignments {
  id         Int        @id @default(autoincrement())
  user_id    Int
  role_id    Int
  status     Boolean?   @default(true)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  user_roles user_roles @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, role_id])
  @@index([role_id], map: "idx_user_role_assignments_role")
  @@index([user_id], map: "idx_user_role_assignments_user")
}

model user_roles {
  id                    Int                     @id @default(autoincrement())
  role_code             String                  @unique @db.VarChar(20)
  role_name             String                  @db.VarChar(100)
  description           String?
  status                Boolean?                @default(true)
  user_role_assignments user_role_assignments[]
}

model users {
  id                                            Int                     @id @default(autoincrement())
  username                                      String                  @unique @db.VarChar(50)
  password                                      String                  @db.VarChar(255)
  email                                         String?                 @unique @db.VarChar(100)
  full_name                                     String                  @db.VarChar(255)
  gender                                        String?                 @db.VarChar(10)
  date_of_birth                                 DateTime?               @db.Date
  phone                                         String?                 @db.VarChar(15)
  address                                       String?
  avatar                                        String?                 @db.VarChar(255)
  status                                        Boolean?                @default(true)
  last_login                                    DateTime?               @db.Timestamp(6)
  created_at                                    DateTime?               @default(now()) @db.Timestamp(6)
  updated_at                                    DateTime?               @default(now()) @db.Timestamp(6)
  FileDB                                        FileDB[]
  FolderDB                                      FolderDB[]
  blocked_users_blocked_users_blocked_idTousers blocked_users[]         @relation("blocked_users_blocked_idTousers")
  blocked_users_blocked_users_blocker_idTousers blocked_users[]         @relation("blocked_users_blocker_idTousers")
  conversation_members                          conversation_members[]
  conversations                                 conversations[]
  final_grades                                  final_grades[]
  instructors                                   instructors?
  message_mentions                              message_mentions[]
  message_reactions                             message_reactions[]
  message_read_status                           message_read_status[]
  messages                                      messages[]
  status_history                                status_history[]
  students                                      students?
  typing_status                                 typing_status[]
  user_role_assignments                         user_role_assignments[]
}

model weekly_report_individual_contributions {
  id                 Int            @id @default(autoincrement())
  weekly_report_id   Int
  student_id         Int
  individual_work    String?
  individual_results String?
  hours_spent        Decimal?       @db.Decimal(6, 2)
  self_evaluation    String?
  created_at         DateTime?      @default(now()) @db.Timestamp(6)
  students           students       @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  weekly_reports     weekly_reports @relation(fields: [weekly_report_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([weekly_report_id, student_id], map: "weekly_report_individual_contri_weekly_report_id_student_id_key")
}

model weekly_reports {
  id                                     Int                                      @id @default(autoincrement())
  thesis_id                              Int
  week_number                            Int
  report_date                            DateTime?                                @default(dbgenerated("CURRENT_DATE")) @db.Date
  work_completed                         String?
  results_achieved                       String?
  difficulties_encountered               String?
  next_week_plan                         String?
  attachment_file                        String?                                  @db.VarChar(255)
  submitted_by                           Int
  student_status                         String?                                  @default("SUBMITTED") @db.VarChar(50)
  instructor_status                      String?                                  @default("PENDING") @db.VarChar(50)
  instructor_feedback                    String?
  weekly_score                           Decimal?                                 @db.Decimal(4, 2)
  feedback_date                          DateTime?                                @db.Timestamp(6)
  created_at                             DateTime?                                @default(now()) @db.Timestamp(6)
  updated_at                             DateTime?                                @default(now()) @db.Timestamp(6)
  weekly_report_individual_contributions weekly_report_individual_contributions[]
  students                               students                                 @relation(fields: [submitted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  theses                                 theses                                   @relation(fields: [thesis_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([thesis_id, week_number])
  @@index([thesis_id], map: "idx_weekly_reports_thesis")
}
