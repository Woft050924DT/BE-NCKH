generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model FileDB {
  id         Int       @id @default(autoincrement())
  slug       String    @db.VarChar(255)
  file_type  Int       @default(1)
  file_tail  String    @db.VarChar(50)
  id_folder  Int?
  id_user    Int
  alt        String?   @db.VarChar(500)
  caption    String?
  status     Int       @default(1)
  full_link  String    @db.VarChar(500)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime  @db.Timestamp(6)
  delete_at  DateTime? @db.Timestamp(6)
  FolderDB   FolderDB? @relation(fields: [id_folder], references: [id], onUpdate: NoAction)
  users      users     @relation(fields: [id_user], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([delete_at])
  @@index([id_folder])
  @@index([id_user])
  @@index([status])
}

model FolderDB {
  id             Int        @id @default(autoincrement())
  name           String     @db.VarChar(255)
  id_parent      Int?
  id_user        Int
  status         Int        @default(1)
  created_at     DateTime   @default(now()) @db.Timestamp(6)
  updated_at     DateTime   @db.Timestamp(6)
  FileDB         FileDB[]
  FolderDB       FolderDB?  @relation("FolderDBToFolderDB", fields: [id_parent], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_FolderDB FolderDB[] @relation("FolderDBToFolderDB")
  users          users      @relation(fields: [id_user], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_parent])
  @@index([id_user])
  @@index([status])
}

model blocked_users {
  id                                    Int       @id @default(autoincrement())
  blocker_id                            Int
  blocked_id                            Int
  reason                                String?
  blocked_at                            DateTime? @default(now()) @db.Timestamp(6)
  users_blocked_users_blocked_idTousers users     @relation("blocked_users_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_blocked_users_blocker_idTousers users     @relation("blocked_users_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([blocker_id, blocked_id])
}

model classes {
  id                   Int                    @id @default(autoincrement())
  class_code           String                 @unique @db.VarChar(20)
  class_name           String                 @db.VarChar(255)
  major_id             Int
  academic_year        String?                @db.VarChar(10)
  student_count        Int?                   @default(0)
  advisor_id           Int?
  status               Boolean?               @default(true)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  updated_at           DateTime?              @default(now()) @db.Timestamp(6)
  majors               majors                 @relation(fields: [major_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instructors          instructors?           @relation(fields: [advisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_classes_advisor")
  students             students[]
  thesis_round_classes thesis_round_classes[]

  @@index([major_id], map: "idx_classes_major")
}

model conversation_members {
  id                   Int           @id @default(autoincrement())
  conversation_id      Int
  user_id              Int
  role                 String?       @default("MEMBER") @db.VarChar(20)
  nickname             String?       @db.VarChar(255)
  joined_at            DateTime?     @default(now()) @db.Timestamp(6)
  left_at              DateTime?     @db.Timestamp(6)
  is_active            Boolean?      @default(true)
  is_muted             Boolean?      @default(false)
  is_pinned            Boolean?      @default(false)
  last_read_message_id Int?
  unread_count         Int?          @default(0)
  created_at           DateTime?     @default(now()) @db.Timestamp(6)
  updated_at           DateTime?     @default(now()) @db.Timestamp(6)
  conversations        conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages             messages?     @relation(fields: [last_read_message_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_conversation_members_last_read")

  @@unique([conversation_id, user_id])
  @@index([conversation_id, is_active], map: "idx_conversation_members_conversation")
  @@index([user_id, unread_count], map: "idx_conversation_members_unread")
  @@index([user_id, is_active], map: "idx_conversation_members_user")
}

model conversation_settings {
  id                     Int           @id @default(autoincrement())
  conversation_id        Int           @unique
  allow_member_invite    Boolean?      @default(true)
  allow_member_remove    Boolean?      @default(false)
  allow_name_change      Boolean?      @default(true)
  allow_avatar_change    Boolean?      @default(true)
  require_admin_approval Boolean?      @default(false)
  created_at             DateTime?     @default(now()) @db.Timestamp(6)
  updated_at             DateTime?     @default(now()) @db.Timestamp(6)
  conversations          conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model conversation_types {
  id            Int             @id @default(autoincrement())
  type_code     String          @unique @db.VarChar(20)
  type_name     String          @db.VarChar(100)
  description   String?
  status        Boolean?        @default(true)
  conversations conversations[]
}

model conversations {
  id                    Int                    @id @default(autoincrement())
  conversation_type_id  Int
  conversation_name     String?                @db.VarChar(255)
  conversation_avatar   String?                @db.VarChar(255)
  created_by_id         Int
  thesis_id             Int?
  is_active             Boolean?               @default(true)
  last_message_at       DateTime?              @db.Timestamp(6)
  created_at            DateTime?              @default(now()) @db.Timestamp(6)
  updated_at            DateTime?              @default(now()) @db.Timestamp(6)
  conversation_members  conversation_members[]
  conversation_settings conversation_settings?
  conversation_types    conversation_types     @relation(fields: [conversation_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 users                  @relation(fields: [created_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  theses                theses?                @relation(fields: [thesis_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  messages              messages[]
  typing_status         typing_status[]

  @@index([last_message_at(sort: Desc)], map: "idx_conversations_last_message")
  @@index([thesis_id], map: "idx_conversations_thesis")
  @@index([conversation_type_id], map: "idx_conversations_type")
}

model council_members {
  id                 Int              @id @default(autoincrement())
  defense_council_id Int
  instructor_id      Int
  role               String           @db.VarChar(50)
  order_number       Int?             @default(1)
  created_at         DateTime?        @default(now()) @db.Timestamp(6)
  defense_councils   defense_councils @relation(fields: [defense_council_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  instructors        instructors      @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([defense_council_id, instructor_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model course_enrollments {
  id                Int                 @id @default(autoincrement())
  student_id        Int
  course_section_id Int
  enrollment_date   DateTime?           @default(now()) @db.Timestamp(6)
  enrollment_type   String?             @default("NORMAL") @db.VarChar(20)
  attempt_number    Int?                @default(1)
  status            String?             @default("ENROLLED") @db.VarChar(30)
  withdrawal_date   DateTime?           @db.Timestamp(6)
  withdrawal_reason String?
  notes             String?
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  updated_at        DateTime?           @default(now()) @db.Timestamp(6)
  course_sections   course_sections     @relation(fields: [course_section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  students          students            @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enrollment_grades enrollment_grades[]
  final_grades      final_grades?

  @@unique([student_id, course_section_id])
  @@index([course_section_id], map: "idx_enrollments_section")
  @@index([student_id, status], map: "idx_enrollments_student")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model course_prerequisites {
  id                                                           Int     @id @default(autoincrement())
  course_id                                                    Int
  prerequisite_course_id                                       Int
  prerequisite_type                                            String? @default("REQUIRED") @db.VarChar(20)
  courses_course_prerequisites_course_idTocourses              courses @relation("course_prerequisites_course_idTocourses", fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  courses_course_prerequisites_prerequisite_course_idTocourses courses @relation("course_prerequisites_prerequisite_course_idTocourses", fields: [prerequisite_course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([course_id, prerequisite_course_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model course_sections {
  id                 Int                  @id @default(autoincrement())
  section_code       String               @unique @db.VarChar(30)
  course_id          Int
  instructor_id      Int
  academic_year      String               @db.VarChar(10)
  semester           Int
  max_students       Int?                 @default(50)
  current_students   Int?                 @default(0)
  room               String?              @db.VarChar(50)
  schedule           String?
  start_date         DateTime?            @db.Date
  end_date           DateTime?            @db.Date
  status             String?              @default("OPEN") @db.VarChar(30)
  notes              String?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  course_enrollments course_enrollments[]
  courses            courses              @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instructors        instructors          @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grade_components   grade_components[]

  @@index([course_id], map: "idx_course_sections_course")
  @@index([instructor_id], map: "idx_course_sections_instructor")
  @@index([academic_year, semester, status], map: "idx_course_sections_semester")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model courses {
  id                                                                        Int                    @id @default(autoincrement())
  course_code                                                               String                 @unique @db.VarChar(20)
  course_name                                                               String                 @db.VarChar(255)
  department_id                                                             Int
  credits                                                                   Int
  theory_hours                                                              Int?                   @default(0)
  practice_hours                                                            Int?                   @default(0)
  course_type                                                               String?                @default("COMPULSORY") @db.VarChar(30)
  description                                                               String?
  prerequisites                                                             String?
  status                                                                    Boolean?               @default(true)
  created_at                                                                DateTime?              @default(now()) @db.Timestamp(6)
  updated_at                                                                DateTime?              @default(now()) @db.Timestamp(6)
  course_prerequisites_course_prerequisites_course_idTocourses              course_prerequisites[] @relation("course_prerequisites_course_idTocourses")
  course_prerequisites_course_prerequisites_prerequisite_course_idTocourses course_prerequisites[] @relation("course_prerequisites_prerequisite_course_idTocourses")
  course_sections                                                           course_sections[]
  departments                                                               departments            @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curriculum_courses                                                        curriculum_courses[]

  @@index([department_id], map: "idx_courses_department")
}

model curriculum {
  id                 Int                  @id @default(autoincrement())
  curriculum_code    String               @unique @db.VarChar(20)
  curriculum_name    String               @db.VarChar(255)
  major_id           Int
  academic_year      String               @db.VarChar(10)
  total_credits      Int
  description        String?
  status             Boolean?             @default(true)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  updated_at         DateTime?            @default(now()) @db.Timestamp(6)
  majors             majors               @relation(fields: [major_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curriculum_courses curriculum_courses[]

  @@index([major_id], map: "idx_curriculum_major")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model curriculum_courses {
  id             Int        @id @default(autoincrement())
  curriculum_id  Int
  course_id      Int
  semester_order Int
  is_optional    Boolean?   @default(false)
  group_code     String?    @db.VarChar(10)
  notes          String?
  courses        courses    @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  curriculum     curriculum @relation(fields: [curriculum_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([curriculum_id, course_id])
  @@index([course_id], map: "idx_curriculum_courses_course")
  @@index([curriculum_id], map: "idx_curriculum_courses_curriculum")
}

model defense_assignments {
  id                 Int               @id @default(autoincrement())
  defense_council_id Int
  thesis_id          Int
  defense_order      Int?
  defense_time       DateTime?         @db.Time(6)
  status             String?           @default("PENDING_DEFENSE") @db.VarChar(50)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  defense_councils   defense_councils  @relation(fields: [defense_council_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  theses             theses            @relation(fields: [thesis_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  defense_results    defense_results[]

  @@unique([defense_council_id, thesis_id])
  @@index([defense_council_id], map: "idx_defense_assignments_council")
  @@index([thesis_id], map: "idx_defense_assignments_thesis")
}

model defense_councils {
  id                                                     Int                   @id @default(autoincrement())
  council_code                                           String                @unique @db.VarChar(50)
  council_name                                           String                @db.VarChar(255)
  thesis_round_id                                        Int
  chairman_id                                            Int
  secretary_id                                           Int?
  defense_date                                           DateTime?             @db.Date
  start_time                                             DateTime?             @db.Time(6)
  end_time                                               DateTime?             @db.Time(6)
  venue                                                  String?               @db.VarChar(255)
  status                                                 String?               @default("PREPARING") @db.VarChar(100)
  notes                                                  String?
  created_at                                             DateTime?             @default(now()) @db.Timestamp(6)
  updated_at                                             DateTime?             @default(now()) @db.Timestamp(6)
  council_members                                        council_members[]
  defense_assignments                                    defense_assignments[]
  instructors_defense_councils_chairman_idToinstructors  instructors           @relation("defense_councils_chairman_idToinstructors", fields: [chairman_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instructors_defense_councils_secretary_idToinstructors instructors?          @relation("defense_councils_secretary_idToinstructors", fields: [secretary_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  thesis_rounds                                          thesis_rounds         @relation(fields: [thesis_round_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([thesis_round_id], map: "idx_defense_councils_round")
}

model defense_results {
  id                    Int                 @id @default(autoincrement())
  defense_assignment_id Int
  instructor_id         Int
  defense_score         Decimal?            @db.Decimal(4, 2)
  comments              String?
  suggestions           String?
  created_at            DateTime?           @default(now()) @db.Timestamp(6)
  defense_assignments   defense_assignments @relation(fields: [defense_assignment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  instructors           instructors         @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([defense_assignment_id, instructor_id])
}

model departments {
  id                                                 Int             @id @default(autoincrement())
  department_code                                    String          @unique @db.VarChar(10)
  department_name                                    String          @db.VarChar(255)
  faculty_id                                         Int
  head_id                                            Int?
  description                                        String?
  status                                             Boolean?        @default(true)
  created_at                                         DateTime?       @default(now()) @db.Timestamp(6)
  updated_at                                         DateTime?       @default(now()) @db.Timestamp(6)
  courses                                            courses[]
  faculties                                          faculties       @relation(fields: [faculty_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instructors_departments_head_idToinstructors       instructors?    @relation("departments_head_idToinstructors", fields: [head_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_departments_head")
  instructors_instructors_department_idTodepartments instructors[]   @relation("instructors_department_idTodepartments")
  majors                                             majors[]
  thesis_rounds                                      thesis_rounds[]

  @@index([faculty_id], map: "idx_departments_faculty")
}

model enrollment_grades {
  id                 Int                @id @default(autoincrement())
  enrollment_id      Int
  grade_component_id Int
  score              Decimal?           @db.Decimal(5, 2)
  graded_by          Int?
  graded_at          DateTime?          @db.Timestamp(6)
  notes              String?
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  updated_at         DateTime?          @default(now()) @db.Timestamp(6)
  course_enrollments course_enrollments @relation(fields: [enrollment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  grade_components   grade_components   @relation(fields: [grade_component_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  instructors        instructors?       @relation(fields: [graded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([enrollment_id, grade_component_id])
  @@index([enrollment_id], map: "idx_enrollment_grades_enrollment")
}

model faculties {
  id            Int             @id @default(autoincrement())
  faculty_code  String          @unique @db.VarChar(10)
  faculty_name  String          @db.VarChar(255)
  dean_id       Int?
  address       String?
  phone         String?         @db.VarChar(15)
  email         String?         @db.VarChar(100)
  status        Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime?       @default(now()) @db.Timestamp(6)
  departments   departments[]
  instructors   instructors?    @relation(fields: [dean_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_faculties_dean")
  thesis_rounds thesis_rounds[]
}

model final_grades {
  id                 Int                @id @default(autoincrement())
  enrollment_id      Int                @unique
  weighted_score     Decimal?           @db.Decimal(5, 2)
  letter_grade       String?            @db.VarChar(5)
  grade_point        Decimal?           @db.Decimal(3, 2)
  is_passed          Boolean?
  is_locked          Boolean?           @default(false)
  locked_by          Int?
  locked_at          DateTime?          @db.Timestamp(6)
  published_at       DateTime?          @db.Timestamp(6)
  notes              String?
  created_at         DateTime?          @default(now()) @db.Timestamp(6)
  updated_at         DateTime?          @default(now()) @db.Timestamp(6)
  course_enrollments course_enrollments @relation(fields: [enrollment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users?             @relation(fields: [locked_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([enrollment_id], map: "idx_final_grades_enrollment")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model grade_components {
  id                Int                 @id @default(autoincrement())
  course_section_id Int
  component_code    String              @db.VarChar(20)
  component_name    String              @db.VarChar(100)
  weight            Decimal             @db.Decimal(5, 2)
  max_score         Decimal?            @default(10) @db.Decimal(5, 2)
  is_required       Boolean?            @default(true)
  order_number      Int?                @default(1)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  enrollment_grades enrollment_grades[]
  course_sections   course_sections     @relation(fields: [course_section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([course_section_id, component_code])
}

model guidance_processes {
  id               Int           @id @default(autoincrement())
  thesis_round_id  Int
  week_number      Int
  phase_name       String        @db.VarChar(255)
  work_description String?
  expected_outcome String?
  status           Boolean?      @default(true)
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  thesis_rounds    thesis_rounds @relation(fields: [thesis_round_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([thesis_round_id, week_number])
}

model instructor_assignments {
  id                Int           @id @default(autoincrement())
  thesis_round_id   Int
  instructor_id     Int
  supervision_quota Int?          @default(0)
  current_load      Int?          @default(0)
  notes             String?
  status            Boolean?      @default(true)
  created_at        DateTime?     @default(now()) @db.Timestamp(6)
  updated_at        DateTime?     @default(now()) @db.Timestamp(6)
  instructors       instructors   @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  thesis_rounds     thesis_rounds @relation(fields: [thesis_round_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([thesis_round_id, instructor_id])
  @@index([instructor_id], map: "idx_instructor_assignments_instructor")
  @@index([thesis_round_id], map: "idx_instructor_assignments_round")
}

model instructors {
  id                                                          Int                      @id @default(autoincrement())
  user_id                                                     Int                      @unique
  instructor_code                                             String                   @unique @db.VarChar(20)
  department_id                                               Int
  degree                                                      String?                  @db.VarChar(100)
  academic_title                                              String?                  @db.VarChar(100)
  specialization                                              String?
  years_of_experience                                         Int?                     @default(0)
  status                                                      Boolean?                 @default(true)
  created_at                                                  DateTime?                @default(now()) @db.Timestamp(6)
  updated_at                                                  DateTime?                @default(now()) @db.Timestamp(6)
  classes                                                     classes[]
  council_members                                             council_members[]
  course_sections                                             course_sections[]
  defense_councils_defense_councils_chairman_idToinstructors  defense_councils[]       @relation("defense_councils_chairman_idToinstructors")
  defense_councils_defense_councils_secretary_idToinstructors defense_councils[]       @relation("defense_councils_secretary_idToinstructors")
  defense_results                                             defense_results[]
  departments_departments_head_idToinstructors                departments[]            @relation("departments_head_idToinstructors")
  enrollment_grades                                           enrollment_grades[]
  faculties                                                   faculties[]
  instructor_assignments                                      instructor_assignments[]
  departments_instructors_department_idTodepartments          departments              @relation("instructors_department_idTodepartments", fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                       users                    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  proposed_topics                                             proposed_topics[]
  review_assignments                                          review_assignments[]
  supervision_comments                                        supervision_comments[]
  theses                                                      theses[]
  topic_registrations                                         topic_registrations[]

  @@index([department_id], map: "idx_instructors_department")
}

model majors {
  id            Int          @id @default(autoincrement())
  major_code    String       @unique @db.VarChar(10)
  major_name    String       @db.VarChar(255)
  department_id Int
  description   String?
  status        Boolean?     @default(true)
  created_at    DateTime?    @default(now()) @db.Timestamp(6)
